{
  "name": "ez-chatbot",
  "description": "EZ Chatbot is a WordPress plugin that allows you to create a custom chatbot for your website using the OpenAI API.",
  "homepage": "https://github.com/medinnna/ez-chatbot",
  "license": "SEE LICENSE IN LICENSE",
  "repository": "github:medinnna/ez-chatbot",
  "private": true,
  "version": "1.2.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && zip -r dist/ez-chatbot.zip dist languages pages index.php LICENSE README.md -x dist/index.html",
    "build-watch": "vite build --watch",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "lucide": "^1.8.0",
    "lucide-react": "^1.8.0",
    "prettier": "3.8.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "rehype-external-links": "^3.0.0",
    "remark-gfm": "^4.0.1",
    "sass": "^1.99.0",
    "vite": "^7.3.2"
  }
}
